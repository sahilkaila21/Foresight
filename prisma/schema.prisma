generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  balance      Float      @default(1000)
  createdAt    DateTime   @default(now())
  markets      Market[]
  trades       Trade[]
  positions    Position[]
  comments     Comment[]
}

model Market {
  id          String     @id @default(cuid())
  question    String
  description String     @default("")
  category    String     @default("Other")
  kind        String     @default("BINARY") // "BINARY" | "CATEGORICAL"
  closesAt    DateTime
  liquidityB  Float      @default(100)
  qYes        Float      @default(0) // binary only
  qNo         Float      @default(0) // binary only
  volume      Float      @default(0) // total |currency| traded, updated per trade
  resolution  String? // binary: "YES"|"NO"; categorical: winning Outcome id
  resolvedAt  DateTime?
  creatorId   String
  creator     User       @relation(fields: [creatorId], references: [id])
  createdAt   DateTime   @default(now())
  trades      Trade[]
  positions   Position[]
  comments    Comment[]
  outcomes    Outcome[]
}

// Categorical-market outcomes. Each holds its own LMSR share quantity `q`.
// For categorical markets, Trade.outcome and Position.outcome store the
// Outcome id; for binary markets those fields hold "YES"/"NO" and no
// Outcome rows exist.
model Outcome {
  id        String @id @default(cuid())
  marketId  String
  market    Market @relation(fields: [marketId], references: [id])
  label     String
  q         Float  @default(0)
  sortOrder Int    @default(0)

  @@index([marketId, sortOrder])
}

model Trade {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  outcome   String // "YES" | "NO"
  shares    Float // positive = buy, negative = sell
  cost      Float // positive = user paid, negative = user received
  probAfter Float
  createdAt DateTime @default(now())

  @@index([marketId, createdAt])
}

model Position {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])
  outcome  String // "YES" | "NO"
  shares   Float  @default(0)

  @@unique([userId, marketId, outcome])
}

model Comment {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([marketId, createdAt])
}
