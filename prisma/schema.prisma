generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase pooled connection (pgBouncer, :6543)
  directUrl = env("DIRECT_URL") // Supabase direct connection (:5432) for migrations / db push
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  balance      Float      @default(1000)
  isAdmin      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  // One-time banner shown after an admin resets the markets, asking the user to
  // re-place their bets. Set on reset, cleared when the user dismisses it.
  showResetNotice Boolean @default(false)
  markets      Market[]
  trades       Trade[]
  positions    Position[]
  comments     Comment[]
  reactions    CommentReaction[]
  watchlist    Watchlist[]
  notifications Notification[]
  limitOrders  LimitOrder[]
  combos       Combo[]
}

model Market {
  id          String     @id @default(cuid())
  question    String
  description String     @default("")
  // Longer analysis paragraph explaining what's driving the odds (like
  // Polymarket's "Market Context"). Empty until an admin/creator writes one.
  context     String     @default("")
  category    String     @default("Other")
  kind        String     @default("BINARY") // "BINARY" | "CATEGORICAL"
  closesAt    DateTime
  // Actual kickoff/event start time for match markets (World Cup), shown on the
  // card and match header. closesAt is the (later) trading cutoff, kept open
  // past kickoff so betting continues during the match. Null for non-match
  // markets, where closesAt alone is shown as "closes X".
  matchStartsAt DateTime?
  liquidityB  Float      @default(5000)
  qYes        Float      @default(0) // binary only
  qNo         Float      @default(0) // binary only
  volume      Float      @default(0) // total |currency| traded, updated per trade
  // Live match state (World Cup match markets), updated by an admin as the game
  // is played. matchStatus: "SCHEDULED" | "LIVE" | "FINAL".
  matchStatus String     @default("SCHEDULED")
  homeScore   Int? // score of outcomes[0] (team A)
  awayScore   Int? // score of outcomes[1] (team B)
  matchMinute String? // free-form clock label, e.g. "63'", "HT", "FT"
  resolution  String? // final winning key, set only on finalize
  resolvedAt  DateTime?
  // Optimistic-oracle resolution state (all null until a proposal is made).
  proposedOutcome String? // proposed winning key (YES/NO or Outcome id)
  proposedById    String?
  proposedAt      DateTime?
  challengeUntil  DateTime? // unchallenged proposals can be finalized after this
  disputed        Boolean   @default(false)
  disputedById    String?
  proposerBond    Float     @default(0)
  disputerBond    Float     @default(0)
  creatorId   String
  creator     User       @relation(fields: [creatorId], references: [id])
  createdAt   DateTime   @default(now())
  trades      Trade[]
  positions   Position[]
  comments    Comment[]
  outcomes    Outcome[]
  watchers    Watchlist[]
  limitOrders LimitOrder[]
  comboLegs   ComboLeg[]
}

// Categorical-market outcomes. Each holds its own LMSR share quantity `q`.
// For categorical markets, Trade.outcome and Position.outcome store the
// Outcome id; for binary markets those fields hold "YES"/"NO" and no
// Outcome rows exist.
model Outcome {
  id        String @id @default(cuid())
  marketId  String
  market    Market @relation(fields: [marketId], references: [id])
  label     String
  q         Float  @default(0)
  sortOrder Int    @default(0)

  @@index([marketId, sortOrder])
}

model Trade {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  outcome   String // "YES" | "NO"
  shares    Float // positive = buy, negative = sell
  cost      Float // positive = user paid, negative = user received
  probAfter Float
  createdAt DateTime @default(now())

  @@index([marketId, createdAt])
}

model Position {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])
  outcome  String // "YES" | "NO"
  shares   Float  @default(0)

  @@unique([userId, marketId, outcome])
}

model Comment {
  id        String   @id @default(cuid())
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())
  reactions CommentReaction[]

  @@index([marketId, createdAt])
}

// Emoji reactions on comments. One row per (comment, user, emoji).
model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  emoji     String
  createdAt DateTime @default(now())

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

// A user's saved/favorited markets.
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, marketId])
  @@index([userId, createdAt])
}

// In-app notifications: market resolution, comments on your markets, limit-order
// fills, combo settlement. `href` is a relative link the bell dropdown navigates to.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // "RESOLVED" | "COMMENT" | "LIMIT_FILLED" | "COMBO"
  body      String
  href      String   @default("")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

// A resting limit order: fills when the outcome's price crosses `limitProb`.
// Buys fill when price <= limitProb (get in cheap); sells fill when price >= limitProb.
// Filled opportunistically inside the trade route whenever another trade moves the price.
model LimitOrder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome   String // "YES"/"NO" or Outcome id
  side      String // "BUY" | "SELL"
  limitProb Float // target price (0..1)
  spend     Float    @default(0) // BUY: currency to spend when it fills
  shares    Float    @default(0) // SELL: shares to sell when it fills
  status    String   @default("OPEN") // "OPEN" | "FILLED" | "CANCELLED"
  createdAt DateTime @default(now())
  filledAt  DateTime?

  @@index([marketId, status])
  @@index([userId, status])
}

// A parlay: stake once, win only if EVERY leg resolves to its chosen outcome.
// combinedProb = product of leg entry prices; payout = stake / combinedProb.
model Combo {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  stake       Float
  combinedProb Float
  payout      Float // stake / combinedProb, paid if it wins
  status      String     @default("OPEN") // "OPEN" | "WON" | "LOST"
  createdAt   DateTime   @default(now())
  settledAt   DateTime?
  legs        ComboLeg[]

  @@index([userId, status])
}

model ComboLeg {
  id        String  @id @default(cuid())
  comboId   String
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market  @relation(fields: [marketId], references: [id], onDelete: Cascade)
  outcome   String // chosen key: "YES"/"NO" or Outcome id
  label     String // human label snapshot
  question  String // market question snapshot
  entryProb Float // price at time of placing
  result    String  @default("PENDING") // "PENDING" | "WON" | "LOST"

  @@index([comboId])
  @@index([marketId])
}
